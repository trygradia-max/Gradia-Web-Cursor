# Canonical site URL for Open Graph / metadata
# NEXT_PUBLIC_SITE_URL=https://www.gradia.com

# Supabase project URL and anon key (required for portal login + queries)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: additional API base URL if you add a custom backend layer
# PORTAL_API_URL=https://api.example.com

# Stripe (server routes under /api/stripe/*)
STRIPE_SECRET_KEY=
# Publishable key (use NEXT_PUBLIC_* if you read it in the browser)
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Supabase service role — required for Stripe routes to update `clients`
SUPABASE_SERVICE_ROLE_KEY=
# Optional: if set, create-subscription and create-performance-invoice require
# Authorization: Bearer <this value>
# STRIPE_INTEGRATION_SECRET=
