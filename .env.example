# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Production: your canonical URL (Auth.js + metadata). Vercel: https://your-project.vercel.app or custom domain
# AUTH_URL=https://www.gradia.com

# Canonical site URL for Open Graph / metadata (optional locally)
# NEXT_PUBLIC_SITE_URL=https://www.gradia.com

# Optional: override default demo password (default is `gradia-demo`)
PORTAL_DEMO_PASSWORD=gradia-demo

# When your API is ready, set the base URL and implement fetch in lib/portal/data.ts
# PORTAL_API_URL=https://api.example.com

# Live dashboard via Supabase (server-side only — never expose the service role to the client)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
